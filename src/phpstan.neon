parameters:
    level: 5
    paths:
        - lib/
        - apps/koohii/lib/
        - apps/koohii/modules/
    excludePaths:
        - apps/koohii/lib/helper/templates
        - apps/koohii/modules/*/templates/*
        - vendor/
    bootstrapFiles:
        - vendor/autoload.php
        - tools/phpstan-bootstrap.php
    scanFiles:
        # for the kk_get_*() global stubs that fix types
        - apps/koohii/config/koohiiConfiguration.class.php
        # Patreon vendor: loaded conditionally via require_once at runtime
        - vendor/friendsofsymfony1/symfony1/lib/helper/AssetHelper.php
        - vendor/friendsofsymfony1/symfony1/lib/helper/EscapingHelper.php
        - vendor/friendsofsymfony1/symfony1/lib/helper/HelperHelper.php
        - vendor/friendsofsymfony1/symfony1/lib/helper/PartialHelper.php
        - vendor/friendsofsymfony1/symfony1/lib/helper/TagHelper.php
        - vendor/friendsofsymfony1/symfony1/lib/helper/UrlHelper.php
    dynamicConstantNames:
        # defined in koohiiConfiguration, not visible to PHPStan statically
        - KK_ENV_DEV
        - KK_ENV_PROD
        - KK_ENV_FORK
